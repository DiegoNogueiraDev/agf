{
  "name": "agent-graph-flow",
  "version": "0.22.1",
  "packageManager": "bun@1.3.14",
  "description": "Agente SWE autônomo, local-first e token-frugal: PRD → grafo de execução persistente, TDD obrigatório, custo de token brutalmente baixo. Apache-2.0.",
  "type": "module",
  "workspaces": [
    "src/web/dashboard"
  ],
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "mcp-graph-agent": "dist/cli/index.js",
    "agent-graph-flow": "dist/cli/index.js",
    "agf": "dist/cli/index.js"
  },
  "scripts": {
    "prepare": "husky",
    "build": "bun build src/index.ts src/cli/index.ts --outdir dist --target node --format esm --packages external && bun run build:types && npm run dashboard:build && npm run copy-dashboard",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "dashboard:install": "npm --prefix src/web/dashboard install",
    "dashboard:dev": "npm --prefix src/web/dashboard run dev",
    "dashboard:build": "npm --prefix src/web/dashboard run build",
    "copy-dashboard": "node -e \"const fs=require('fs');if(fs.existsSync('dist/web/dashboard/dist')){fs.rmSync('dist/web/dashboard/dist',{recursive:true})};fs.mkdirSync('dist/web/dashboard',{recursive:true});fs.cpSync('src/web/dashboard/dist','dist/web/dashboard/dist',{recursive:true})\"",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build && bun run typecheck",
    "pack:offline": "node scripts/pack-offline.mjs",
    "pack:bun": "node scripts/pack-bun.mjs",
    "pack:bun:host": "node scripts/pack-bun.mjs --host",
    "publish:private": "node scripts/publish-private.mjs",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:node": "vitest run --project=node",
    "test:blast": "vitest run --changed HEAD --project=node",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.tsx\" \"*.json\" \"*.md\"",
    "lint": "eslint src/ --max-warnings 1000",
    "lint:fix": "eslint src/ --fix",
    "demo": "npm run build && node scripts/demo.mjs",
    "showcase": "npm run build && node scripts/showcase.mjs",
    "test:blast:full": "vitest run --changed HEAD",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run --coverage --config vitest.coverage.config.ts",
    "test:clear": "vitest --clearCache",
    "harness:scan": "tsx src/cli/index.ts harness",
    "harness:gate": "tsx src/cli/index.ts harness --gate",
    "economy:gate": "tsx src/cli/index.ts eval --suite economy --gate",
    "sync:prices": "tsx scripts/sync-openrouter-prices.ts",
    "ci:smoke": "npm run typecheck && npm run lint && npm run audit:stubs && npm run check:dead-exports && vitest run src/tests/e2e-cli-smoke.test.ts && npm run test:smoke",
    "check:dead-exports": "node scripts/check-dead-exports.mjs",
    "test:import-boundary": "node scripts/enforce-import-boundary.mjs",
    "audit:stubs": "node scripts/audit-stubs.mjs",
    "skills:sync": "node scripts/sync-skills.mjs",
    "skills:publish": "node scripts/sync-public-skills.mjs",
    "gen:command-surface": "tsx scripts/gen-command-surface.mts"
  },
  "keywords": [
    "swe-agent",
    "autonomous-agent",
    "prd",
    "task-graph",
    "local-first",
    "token-frugal",
    "tdd",
    "mcp"
  ],
  "files": [
    "dist/",
    "src/skills/",
    "README.md",
    "LICENSE"
  ],
  "author": "Diego Lima Nogueira de Paula (https://github.com/DiegoNogueiraDev)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DiegoNogueiraDev/agf.git"
  },
  "homepage": "https://github.com/DiegoNogueiraDev/agf#readme",
  "bugs": {
    "url": "https://github.com/DiegoNogueiraDev/agf/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.3",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-security": "^4.0.1",
    "graphology": "^0.26.0",
    "graphology-types": "^0.24.8",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "node-gyp": "^12.4.0",
    "prettier": "^3.9.4",
    "react-devtools-core": "file:./stubs/react-devtools-core",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-lua": "^2.1.3",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-swift": "^0.7.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/react": "^19.2.17",
    "adm-zip": "^0.5.18",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.9.3",
    "glob": "^13.0.6",
    "ink": "^6.8.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "lru-cache": "^11.2.7",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "smol-toml": "^1.7.0",
    "ts-morph": "^28.0.0",
    "web-tree-sitter": "^0.26.10",
    "ws": "^8.21.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@github/copilot-sdk": "^1.0.5",
    "onnxruntime-node": "^1.27.0",
    "typescript": "^6.0.2",
    "typescript-language-server": ">=5.3.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0 || >=6.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "overrides": {
    "basic-ftp": ">=6.0.0",
    "protobufjs": ">=8.0.2",
    "@protobufjs/utf8": ">=1.1.1",
    "ip-address": ">=10.1.1",
    "@tootallnate/once": ">=3.0.1",
    "fast-uri": ">=3.1.2",
    "js-cookie": ">=3.0.6"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
